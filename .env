ADMIN_EMAIL=admin@admin.fr
ADMIN_PASSWORD=admin
JWT_SECRET=super_secret_local_key_for_jwt_tokens_12345

# Point de depart pour le calcul des frais de livraison
# (valeur de depart seulement — modifiable ensuite depuis Espace OA > Reglages)
DEPOT_ADDRESS=72 rue Victor Basch, 92120 Montrouge, France
DELIVERY_BASE_FEE=15
DELIVERY_PER_KM=1.2

# ───── Paiement en ligne (Stripe) ─────
# Tant que ces cles sont vides, le paiement en ligne est desactive : le
# formulaire de reservation revient a son comportement d'origine (demande
# envoyee sans etape de paiement). Pour l'activer :
#   1. Creer un compte sur https://dashboard.stripe.com/register (gratuit)
#   2. Mode test d'abord : cles sur https://dashboard.stripe.com/test/apikeys
#      - STRIPE_SECRET_KEY = "Secret key" (sk_test_...)
#      - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = "Publishable key" (pk_test_...)
#   3. Webhook (necessaire pour confirmer les paiements de facon fiable) :
#      https://dashboard.stripe.com/test/webhooks > Add endpoint
#      URL : https://votre-domaine.fr/api/payments/webhook
#      Evenements a cocher : payment_intent.succeeded, payment_intent.payment_failed
#      -> copier le "Signing secret" (whsec_...) dans STRIPE_WEBHOOK_SECRET
#   4. Repeter en mode Live une fois pret a encaisser reellement (cles sk_live_/pk_live_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Le virement bancaire (IBAN/BIC affiches au client) se configure entierement
# depuis Espace OA > Reglages — rien a ajouter ici pour cette option.

# Prelevement des echeances suivantes (paiement en plusieurs fois) : ce site
# est auto-heberge et n'a pas de tache planifiee integree. Executer une fois
# par jour, via le Planificateur de taches Windows par exemple :
#   node scripts/run-scheduled-payments.js   (depuis le dossier du projet)

# ───── Email automatique (Resend) ─────
# Envoie au client l'email de confirmation/refus (avec le numero de commande
# et le lien vers /suivi) quand l'admin clique Confirmer/Refuser dans
# Espace OA. Tant que RESEND_API_KEY est vide, rien n'est envoye (juste un
# message dans les logs du serveur) — aucun impact sur le reste du site.
#   1. Compte gratuit sur https://resend.com (100 emails/jour, 3000/mois)
#   2. Cle API : https://resend.com/api-keys -> coller dans RESEND_API_KEY
#   3. EMAIL_FROM : sans domaine verifie, utiliser la valeur par defaut
#      "onboarding@resend.dev" (fonctionne tout de suite, en mode test).
#      Pour un vrai domaine (ex: contact@oa-evenementiel.fr), le verifier
#      d'abord sur https://resend.com/domains
RESEND_API_KEY=
EMAIL_FROM=OA Événementiel <onboarding@resend.dev>

# URL publique du site, utilisee dans le lien "Suivre ma demande" des emails.
# Sans ca, l'app devine a partir de l'en-tete Host de la requete (fonctionne
# en local et sur la plupart des hebergeurs, mais mieux vaut la fixer en prod).
NEXT_PUBLIC_SITE_URL=
